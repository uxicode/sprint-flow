# 환경 변수 템플릿 (SaaS 버전)

# ============================================================================
# Database (필수)
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/sprintflow"

# ============================================================================
# NextAuth.js (필수)
# ============================================================================
# 랜덤 문자열 생성: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-key-32-characters-or-more"

# 로컬: http://localhost:3000
# 프로덕션: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# OAuth Providers (선택사항)
# ============================================================================
# Google OAuth 2.0
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================================================
# Cron Job 보안 (필수)
# ============================================================================
# 랜덤 문자열 생성: openssl rand -base64 32
CRON_SECRET="your-cron-secret-key"

# ============================================================================
# 데이터 암호화 (프로덕션 필수)
# ============================================================================
# 64자리 hex 문자열 생성: openssl rand -hex 32
ENCRYPTION_KEY="your-64-character-hex-encryption-key-here"

# ============================================================================
# 기타 설정 (선택사항)
# ============================================================================
NODE_ENV="development"
